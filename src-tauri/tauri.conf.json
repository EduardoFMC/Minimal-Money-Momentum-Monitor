{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minimal Money Momentum Monitor",
  "version": "0.1.0",
  "identifier": "br.com.eduardo.m4",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Minimal Money Momentum Monitor",
        "width": 960,
        "height": 540,
        "minWidth": 620,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
